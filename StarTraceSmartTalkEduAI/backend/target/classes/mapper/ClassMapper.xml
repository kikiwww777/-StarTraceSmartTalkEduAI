<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eduai.Mapper.ClassMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.eduai.pojo.entity.Class">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="class_name" property="className" jdbcType="VARCHAR"/>
        <result column="class_code" property="classCode" jdbcType="VARCHAR"/>
        <result column="teacher_id" property="teacherId" jdbcType="BIGINT"/>
        <result column="course_id" property="courseId" jdbcType="BIGINT"/>
        <result column="description" property="description" jdbcType="LONGVARCHAR"/>
        <result column="status" property="status" jdbcType="TINYINT"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>
    
    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, class_name, class_code, teacher_id, course_id, description, status, created_at, updated_at
    </sql>
    
    <!-- 根据ID查询班级 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM classes
        WHERE id = #{id}
    </select>
    
    <!-- 根据班级代码查询班级 -->
    <select id="selectByClassCode" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM classes
        WHERE class_code = #{classCode}
    </select>
    
    <!-- 根据教师ID查询班级列表 -->
    <select id="selectByTeacherId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM classes
        WHERE teacher_id = #{teacherId}
        ORDER BY created_at DESC
    </select>
    
    <!-- 根据课程ID查询班级列表 -->
    <select id="selectByCourseId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM classes
        WHERE course_id = #{courseId}
        ORDER BY created_at DESC
    </select>

    <!-- 根据课程ID + 教师ID查询班级列表 -->
    <select id="selectByCourseIdAndTeacherId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM classes
        WHERE course_id = #{courseId}
          AND teacher_id = #{teacherId}
        ORDER BY created_at DESC
    </select>
    
    <!-- 查询所有班级 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM classes
        ORDER BY created_at DESC
    </select>
    
    <!-- 插入新班级 -->
    <insert id="insert" parameterType="com.eduai.pojo.entity.Class" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO classes (
            class_name, class_code, teacher_id, course_id, description, status,
            created_at, updated_at
        ) VALUES (
            #{className}, #{classCode}, #{teacherId}, #{courseId}, #{description}, #{status},
            #{createdAt}, #{updatedAt}
        )
    </insert>
    
    <!-- 更新班级信息 -->
    <update id="update" parameterType="com.eduai.pojo.entity.Class">
        UPDATE classes
        <set>
            <if test="className != null">class_name = #{className},</if>
            <if test="classCode != null">class_code = #{classCode},</if>
            <if test="teacherId != null">teacher_id = #{teacherId},</if>
            <if test="courseId != null">course_id = #{courseId},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 根据ID删除班级 -->
    <delete id="deleteById">
        DELETE FROM classes
        WHERE id = #{id}
    </delete>
    
</mapper>

