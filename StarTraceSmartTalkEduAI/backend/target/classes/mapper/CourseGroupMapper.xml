<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eduai.Mapper.CourseGroupMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.eduai.pojo.entity.CourseGroup">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="course_id" property="courseId" jdbcType="BIGINT"/>
        <result column="teacher_id" property="teacherId" jdbcType="BIGINT"/>
        <result column="semester" property="semester" jdbcType="VARCHAR"/>
        <result column="max_students" property="maxStudents" jdbcType="INTEGER"/>
        <result column="current_students" property="currentStudents" jdbcType="INTEGER"/>
        <result column="status" property="status" jdbcType="TINYINT"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>
    
    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, course_id, teacher_id, semester, max_students, current_students, status, created_at, updated_at
    </sql>
    
    <!-- 根据ID查询课程组 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM course_groups
        WHERE id = #{id}
    </select>
    
    <!-- 根据教师ID查询课程组列表 -->
    <select id="selectByTeacherId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM course_groups
        WHERE teacher_id = #{teacherId}
        <if test="semester != null and semester != ''">
            AND semester = #{semester}
        </if>
        ORDER BY id DESC
    </select>
    
    <!-- 根据学期查询课程组列表 -->
    <select id="selectBySemester" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM course_groups
        WHERE semester = #{semester}
        ORDER BY id DESC
    </select>
    
    <!-- 根据课程ID查询课程组列表 -->
    <select id="selectByCourseId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM course_groups
        WHERE course_id = #{courseId}
        ORDER BY id DESC
    </select>

    <!-- 查询某教师开设某课程的最新课程组 -->
    <select id="selectLatestByCourseIdAndTeacherId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM course_groups
        WHERE course_id = #{courseId}
          AND teacher_id = #{teacherId}
        ORDER BY created_at DESC, id DESC
        LIMIT 1
    </select>
    
    <!-- 插入新课程组 -->
    <insert id="insert" parameterType="com.eduai.pojo.entity.CourseGroup" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO course_groups (
            course_id, teacher_id, semester, max_students, current_students, status, created_at, updated_at
        ) VALUES (
            #{courseId}, #{teacherId}, #{semester}, #{maxStudents}, #{currentStudents}, #{status}, #{createdAt}, #{updatedAt}
        )
    </insert>
    
    <!-- 更新课程组信息 -->
    <update id="update" parameterType="com.eduai.pojo.entity.CourseGroup">
        UPDATE course_groups
        <set>
            <if test="courseId != null">course_id = #{courseId},</if>
            <if test="teacherId != null">teacher_id = #{teacherId},</if>
            <if test="semester != null">semester = #{semester},</if>
            <if test="maxStudents != null">max_students = #{maxStudents},</if>
            <if test="currentStudents != null">current_students = #{currentStudents},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 根据ID删除课程组 -->
    <delete id="deleteById">
        DELETE FROM course_groups
        WHERE id = #{id}
    </delete>
    
    <!-- 更新当前学生数 -->
    <update id="updateCurrentStudents">
        UPDATE course_groups
        SET current_students = #{currentStudents},
            updated_at = NOW()
        WHERE id = #{id}
    </update>
    
</mapper>



