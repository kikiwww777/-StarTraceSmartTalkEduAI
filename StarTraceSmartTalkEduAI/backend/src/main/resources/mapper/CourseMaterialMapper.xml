<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eduai.Mapper.CourseMaterialMapper">

    <resultMap id="BaseResultMap" type="com.eduai.pojo.entity.CourseMaterial">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="group_id" property="groupId" jdbcType="BIGINT"/>
        <result column="uploader_id" property="uploaderId" jdbcType="BIGINT"/>
        <result column="title" property="title" jdbcType="VARCHAR"/>
        <result column="type" property="type" jdbcType="VARCHAR"/>
        <result column="content" property="content" jdbcType="LONGVARCHAR"/>
        <result column="url" property="url" jdbcType="VARCHAR"/>

        <result column="original_filename" property="originalFilename" jdbcType="VARCHAR"/>
        <result column="stored_filename" property="storedFilename" jdbcType="VARCHAR"/>
        <result column="file_path" property="filePath" jdbcType="VARCHAR"/>
        <result column="content_type" property="contentType" jdbcType="VARCHAR"/>
        <result column="file_size" property="fileSize" jdbcType="BIGINT"/>

        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, group_id, uploader_id, title, type, content, url,
        original_filename, stored_filename, file_path, content_type, file_size,
        created_at, updated_at
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM course_materials
        WHERE id = #{id}
    </select>

    <select id="selectByGroupId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM course_materials
        WHERE group_id = #{groupId}
        ORDER BY updated_at DESC, id DESC
    </select>

    <insert id="insert" parameterType="com.eduai.pojo.entity.CourseMaterial" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO course_materials (
            group_id, uploader_id, title, type, content, url,
            original_filename, stored_filename, file_path, content_type, file_size,
            created_at, updated_at
        ) VALUES (
            #{groupId}, #{uploaderId}, #{title}, #{type}, #{content}, #{url},
            #{originalFilename}, #{storedFilename}, #{filePath}, #{contentType}, #{fileSize},
            #{createdAt}, #{updatedAt}
        )
    </insert>

    <update id="update" parameterType="com.eduai.pojo.entity.CourseMaterial">
        UPDATE course_materials
        <set>
            <if test="groupId != null">group_id = #{groupId},</if>
            <if test="uploaderId != null">uploader_id = #{uploaderId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="type != null">type = #{type},</if>
            <if test="content != null">content = #{content},</if>
            <if test="url != null">url = #{url},</if>

            <if test="originalFilename != null">original_filename = #{originalFilename},</if>
            <if test="storedFilename != null">stored_filename = #{storedFilename},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="contentType != null">content_type = #{contentType},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>

            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM course_materials
        WHERE id = #{id}
    </delete>

</mapper>


